generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../lib/generated/zod"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(uuid())
  name      String   @default("admin")
  email     String   @unique
  password  String
  role      Role?    @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Company {
  id        String    @id @default(uuid())
  name      String    @db.VarChar(50)
  address   String    @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  clients   Client[]
  products  Product[] @relation("CompanyToProduct")
}

model Client {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(50)
  email       String          @unique
  password    String
  phone       String          @unique
  address     String          @db.VarChar(100)
  role        Role            @default(CLIENT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  companyName String?
  companyID   String?
  isShowPrice Boolean         @default(false)
  company     Company?        @relation(fields: [companyID], references: [id])
  products    ClientProduct[]
  orders      Order[]
}

model ProductCategory {
  id            String        @id @default(uuid())
  name          String        @unique @db.VarChar(50)
  displayName   String        @db.VarChar(100)
  description   String?       @db.VarChar(255)
  shortCode     String        @unique @db.VarChar(10)
  isActive      Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  products      Product[]
  subCategories SubCategory[]
}

model Product {
  id                    String            @id @default(uuid())
  name                  String            @db.VarChar(50)
  images                String[]
  price                 Int?
  sku                   String            @unique @db.VarChar(100)
  availableStock        Int
  description           String
  categories            Category?
  avgRating             Float?
  noOfReviews           Int?
  brand                 String?           @db.VarChar(30)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  inventoryUpdateReason Reason?
  inventoryLogs         String[]
  categoryId            String?
  minStockThreshold     Int?
  subCategoryId         String?
  bundleItems           BundleItem[]
  bundleOrderItems      BundleOrderItem[]
  clients               ClientProduct[]
  orderItems            OrderItem[]
  category              ProductCategory?  @relation(fields: [categoryId], references: [id])
  subCategory           SubCategory?      @relation(fields: [subCategoryId], references: [id])
  companies             Company[]         @relation("CompanyToProduct")
}

model SubCategory {
  id         String          @id @default(uuid())
  name       String
  categoryId String
  shortCode  String          @unique @db.VarChar(10)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  products   Product[]
  category   ProductCategory @relation(fields: [categoryId], references: [id])
}

model Order {
  id                    String            @id @default(uuid())
  totalAmount           Float
  clientId              String?
  createdAt             DateTime          @default(now())
  deliveryAddress       String            @default("Address")
  note                  String?
  updatedAt             DateTime          @updatedAt
  status                Status            @default(PENDING)
  city                  String            @default("City")
  consigneeEmail        String            @default("email@example.com")
  consigneeName         String            @default("Name")
  consigneePhone        String            @default("0000000000")
  modeOfDelivery        Modes             @default(SURFACE)
  pincode               String            @default("000000")
  state                 String            @default("State")
  deliveryReference     String?
  packagingInstructions String?
  requiredByDate        DateTime
  consignmentNumber     String?
  deliveryService       String?
  isMailSent            Boolean           @default(false)
  shippingLabelUrl      String?
  numberOfBundles       Int?
  bundles               Bundle[]
  bundleOrderItems      BundleOrderItem[]
  client                Client?           @relation(fields: [clientId], references: [id])
  emails                OrderEmail[]
  orderItems            OrderItem[]
}

model OrderEmail {
  id        String    @id @default(uuid())
  orderId   String
  purpose   Status
  isSent    Boolean   @default(false)
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, purpose])
}

model BundleOrderItem {
  id          String       @id @default(uuid())
  bundleId    String
  orderId     String
  productId   String
  quantity    Int          @default(1)
  price       Float
  bundle      Bundle       @relation(fields: [bundleId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  bundleItems BundleItem[] @relation("BundleItemToBundleOrderItem")
}

model BundleItem {
  id                    String            @id @default(uuid())
  productId             String
  price                 Float
  bundleId              String
  bundleProductQuantity Int               @default(1)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  bundle                Bundle            @relation(fields: [bundleId], references: [id])
  product               Product           @relation(fields: [productId], references: [id])
  bundleOrderItems      BundleOrderItem[] @relation("BundleItemToBundleOrderItem")
}

model Bundle {
  id               String            @id @default(uuid())
  orderId          String?
  price            Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  numberOfBundles  Int?
  order            Order?            @relation(fields: [orderId], references: [id])
  items            BundleItem[]
  bundleOrderItems BundleOrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int     @default(1)
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ResetToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  password   String
  userId     String?
  userType   Role?
}

model LoginToken {
  id         String   @id @default(uuid())
  token      String   @unique
  identifier String
  password   String
  userId     String?
  userType   Role?
  createdAt  DateTime @default(now())
  expires    DateTime
}

model ClientProduct {
  id        String   @id @default(uuid())
  clientId  String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([clientId, productId])
}

model SystemRole {
  id          String             @id @default(uuid())
  name        String             @unique @db.VarChar(50)
  description String?            @db.VarChar(255)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  users       SystemUser[]
  permissions SystemPermission[] @relation("SystemPermissionToSystemRole")
}

model SystemPermission {
  id          String       @id @default(uuid())
  resource    String       @db.VarChar(50)
  action      String       @db.VarChar(20)
  description String?      @db.VarChar(255)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  roles       SystemRole[] @relation("SystemPermissionToSystemRole")

  @@unique([resource, action])
}

model SystemUser {
  id        String     @id @default(uuid())
  name      String     @db.VarChar(100)
  email     String     @unique
  password  String
  isActive  Boolean    @default(true)
  roleId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  role      SystemRole @relation(fields: [roleId], references: [id])
}

model OMClient {
  id             String            @id @default(uuid())
  name           String            @unique @db.VarChar(100)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  billingAddress String?           @db.VarChar(500)
  contactPerson  String?           @db.VarChar(100)
  email          String?           @unique @db.VarChar(100)
  gstNumber      String?           @db.VarChar(20)
  notes          String?           @db.VarChar(1000)
  phone          String?           @db.VarChar(20)
  pos            OMPurchaseOrder[]
}

model OMDeliveryLocation {
  id        String            @id @default(uuid())
  name      String            @unique @db.VarChar(100)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  pos       OMPurchaseOrder[]
}

model OMPurchaseOrder {
  id               String                @id @default(uuid())
  clientId         String
  locationId       String?
  estimateNumber   String?
  estimateDate     DateTime?
  poNumber         String?               @unique
  poDate           DateTime?
  poReceivedDate   DateTime?
  status           OMPoStatus            @default(DRAFT)
  totalGst         Float                 @default(0)
  grandTotal       Float                 @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  dispatchOrders   OMDispatchOrder[]
  client           OMClient              @relation(fields: [clientId], references: [id])
  deliveryLocation OMDeliveryLocation?   @relation(fields: [locationId], references: [id])
  items            OMPurchaseOrderItem[]
}

model OMProduct {
  id                 String                @id @default(uuid())
  name               String                @db.VarChar(100)
  sku                String?               @unique @db.VarChar(100)
  description        String?               @db.VarChar(255)
  price              Float?
  defaultGstPct      Float                 @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  isActive           Boolean               @default(true)
  brands             OMBrand[]             @relation("OMProductBrands")
  purchaseOrderItems OMPurchaseOrderItem[]
  ombrands           OMBrand[]
}

model OMPurchaseOrderItem {
  id              String                @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  rate            Float
  amount          Float
  gstPercentage   Float
  gstAmount       Float
  totalAmount     Float
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  brandId         String?
  description     String?               @db.VarChar(255)
  dispatchItems   OMDispatchOrderItem[]
  OMBrand         OMBrand?              @relation(fields: [brandId], references: [id])
  product         OMProduct             @relation(fields: [productId], references: [id])
  purchaseOrder   OMPurchaseOrder       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model OMLogisticsPartner {
  id             String            @id @default(uuid())
  name           String            @unique @db.VarChar(100)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  contactPerson  String?           @db.VarChar(100)
  defaultMode    Modes             @default(SURFACE)
  email          String?           @db.VarChar(100)
  phone          String?           @db.VarChar(20)
  dispatchOrders OMDispatchOrder[]
}

model OMDispatchOrder {
  id                   String                @id @default(uuid())
  purchaseOrderId      String
  invoiceNumber        String?               @unique
  invoiceDate          DateTime?
  logisticsPartnerId   String?
  docketNumber         String?
  expectedDeliveryDate DateTime?
  status               OMDispatchStatus      @default(PENDING)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  logisticsPartner     OMLogisticsPartner?   @relation(fields: [logisticsPartnerId], references: [id])
  purchaseOrder        OMPurchaseOrder       @relation(fields: [purchaseOrderId], references: [id])
  items                OMDispatchOrderItem[]
  shipmentBoxes        OMShipmentBox[]
}

model OMDispatchOrderItem {
  id                  String              @id @default(uuid())
  dispatchOrderId     String
  purchaseOrderItemId String
  quantity            Int
  rate                Float
  amount              Float
  gstPercentage       Float
  gstAmount           Float
  totalAmount         Float
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  dispatchOrder       OMDispatchOrder     @relation(fields: [dispatchOrderId], references: [id], onDelete: Cascade)
  purchaseOrderItem   OMPurchaseOrderItem   @relation(fields: [purchaseOrderItemId], references: [id])
  shipmentBoxContents OMShipmentBoxContent[]
}

model OMShipmentBox {
  id              String                @id @default(uuid())
  dispatchOrderId String
  boxLabel        String? // e.g., "Box 1", "Medium Carton"
  length          Float // in cm
  width           Float // in cm
  height          Float // in cm
  numberOfBoxes   Int                   @default(1) // Number of identical boxes
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  dispatchOrder OMDispatchOrder        @relation(fields: [dispatchOrderId], references: [id], onDelete: Cascade)
  contents      OMShipmentBoxContent[]

  @@index([dispatchOrderId])
}

model OMShipmentBoxContent {
  id                  String              @id @default(uuid())
  shipmentBoxId       String
  dispatchOrderItemId String
  quantityPerBox      Int // Quantity inside EACH physical box
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  shipmentBox       OMShipmentBox       @relation(fields: [shipmentBoxId], references: [id], onDelete: Cascade)
  dispatchOrderItem OMDispatchOrderItem @relation(fields: [dispatchOrderItemId], references: [id], onDelete: Cascade)

  @@index([shipmentBoxId])
  @@index([dispatchOrderItemId])
}

model OMBrand {
  id                  String                @id
  name                String                @unique @db.VarChar(100)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  products            OMProduct[]           @relation("OMProductBrands")
  OMPurchaseOrderItem OMPurchaseOrderItem[]
  omproduct           OMProduct?            @relation(fields: [oMProductId], references: [id])
  oMProductId         String?
}

enum Category {
  stationery
  accessories
  funAndStickers
  drinkware
  apparel
  travelAndTech
  books
  welcomeKit
  newcategory
  consumables
}

enum Status {
  PENDING
  APPROVED
  CANCELLED
  READY_FOR_DISPATCH
  DISPATCHED
  AT_DESTINATION
  DELIVERED
}

enum Modes {
  AIR
  SURFACE
  HAND_DELIVERY
}

enum Reason {
  NEW_PURCHASE
  PHYSICAL_STOCK_CHECK
  RETURN_FROM_PREVIOUS_DISPATCH
  NEW_ORDER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  ADMIN
  CLIENT
  SYSTEM_USER
}

enum OMPoStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_DISPATCHED
  FULLY_DISPATCHED
  CLOSED
}

enum OMDispatchStatus {
  PENDING
  APPROVED
  READY_FOR_DISPATCH
  DISPATCHED
  AT_DESTINATION
  DELIVERED
  CANCELLED
}
